@model IEnumerable<benhvien.Models.Notification>

@{
    ViewData["Title"] = "Thông báo của tôi";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="text-danger fw-bold">
                    <i class="bi bi-bell-fill"></i> Hộp thư thông báo
                </h2>
                <span class="badge bg-secondary">Tổng số: @Model.Count()</span>
            </div>

            @if (!Model.Any())
            {
                <div class="alert alert-info text-center shadow-sm" role="alert">
                    <i class="bi bi-info-circle"></i> Hiện tại bạn chưa có thông báo nào phù hợp với nhóm máu của mình.
                </div>
            }
            else
            {
                <div class="list-group shadow-sm">
                    @foreach (var noti in Model)
                    {
                        <div class="list-group-item list-group-item-action p-3 mb-2 border-start border-danger border-4 rounded shadow-sm @(noti.IsRead ? "" : "bg-light")">
                            <div class="d-flex w-100 justify-content-between align-items-center">
                                <h5 class="mb-1 text-dark fw-bold">@noti.Title</h5>
                                <small class="text-muted">
                                    <i class="bi bi-clock"></i> @noti.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                </small>
                            </div>
                            <p class="mb-1 text-secondary mt-2" style="white-space: pre-line;">
                                @noti.Message
                            </p>
                            <div class="text-end mt-2">
                                @if (!noti.IsRead)
                                {
                                    <span class="badge bg-danger rounded-pill">Chưa đọc</span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-dark border">Đã đọc</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>