@model List<benhvien.Models.BloodRequest>

<h2 class="mb-4">
    Danh sách bài đăng
</h2>

<a asp-action="Create"
   class="btn btn-danger mb-3">

    Tạo bài đăng

</a>

<table class="table table-bordered">

    <tr>
        <th>ID</th>
        <th>Nhóm máu</th>
        <th>Số lượng</th>
        <th>Khẩn cấp</th>
        <th>Ngày tạo</th>
        <th>Action</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>

            <td>@item.Id</td>

            <td>@item.BloodType</td>

            <td>@item.QuantityNeeded</td>

            <td>

                @(item.IsUrgent ? "YES" : "NO")

            </td>

            <td>@item.CreatedAt</td>

            <td>

                <a asp-action="Edit"
                   asp-route-id="@item.Id"
                   class="btn btn-warning">

                    Edit

                </a>

                <a asp-action="Delete"
                   asp-route-id="@item.Id"
                   class="btn btn-danger">

                    Delete

                </a>

            </td>

        </tr>
    }

</table>