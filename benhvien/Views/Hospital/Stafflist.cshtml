@{
    Layout = "_LayoutAdmin";
}
@model List<benhvien.Models.User>

<h2>Danh sách nhân viên</h2>

<a asp-action="CreateStaff"
   class="btn btn-success mb-3">
    Thêm nhân viên
</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Họ tên</th>
            <th>Email</th>
            <th>SĐT</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.FullName</td>
                <td>@item.Email</td>
                <td>@item.Phone</td>
            </tr>
        }
    </tbody>
</table>
<a asp-controller="Hospital" asp-action="Index" class="btn btn-secondary">
    Quay lại
</a>