@{
    Layout = "_LayoutAdmin";
}
@model IEnumerable<benhvien.Models.BloodRequest>

@{
    ViewData["Title"] = "Quản lý yêu cầu máu";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between mb-3">
        <h2>Yêu cầu máu của tôi</h2>

        <a asp-action="Create" class="btn btn-danger">
            + Đăng yêu cầu
        </a>
    </div>

    <table class="table table-bordered table-hover">

        <thead class="table-dark">
            <tr>
                <th>Nhóm máu</th>
                <th>Số lượng</th>
                <th>Khẩn cấp</th>
                <th>Ngày tạo</th>
                <th width="220">Thao tác</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <td>@item.BloodType</td>

                    <td>@item.QuantityNeeded</td>

                    <td>
                        @(item.IsUrgent ? "🔴 Có" : "Không")
                    </td>

                    <td>
                        @item.CreatedAt.ToString("dd/MM/yyyy")
                    </td>

                    <td>

                        <a asp-action="Edit"
                           asp-route-id="@item.Id"
                           class="btn btn-warning btn-sm">
                            Sửa
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.Id"
                           class="btn btn-danger btn-sm">
                            Xóa
                        </a>

                    </td>

                </tr>
            }

        </tbody>

    </table>
    <div class="col-12 mt-5 text-center">
        <div class="p-4 bg-light rounded shadow-sm border">
            <h4 class="text-muted mb-3"><i class="bi bi-gear-fill"></i> </h4>
            <div class="d-flex justify-content-center gap-3">

                <a asp-controller="Hospital"
                   asp-action="CreateStaff"
                   class="btn btn-primary btn-lg px-4 py-3 shadow-sm d-flex align-items-center">
                    <i class="bi bi-hospital me-2 fs-4"></i>
                    <span class="fw-bold">Tạo tài khoản</span>
                </a>

                <a asp-controller="Hospital"
                   asp-action="Stafflist"
                   class="btn btn-success btn-lg px-4 py-3 shadow-sm d-flex align-items-center">
                    <i class="bi bi-people-fill me-2 fs-4"></i>
                    <span class="fw-bold">Danh sách tài khoản</span>
                </a>

            </div>
        </div>
</div>