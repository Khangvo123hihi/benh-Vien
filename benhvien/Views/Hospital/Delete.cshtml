@model benhvien.Models.BloodRequest

<div class="container mt-4">

    <div class="card">

        <div class="card-header bg-danger text-white">
            Xác nhận xóa
        </div>

        <div class="card-body">

            <h5>
                Bạn có chắc muốn xóa yêu cầu máu
                "@Model.BloodType" ?
            </h5>

            <hr />

            <p>
                Số lượng:
                <strong>@Model.QuantityNeeded</strong>
            </p>

            <form asp-action="Delete">

                <input asp-for="Id" type="hidden" />

                <button class="btn btn-danger">
                    Xóa
                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">
                    Hủy
                </a>

            </form>

        </div>

    </div>

</div>