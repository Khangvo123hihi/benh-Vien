@using Microsoft.AspNetCore.Http
@using benhvien.Data
@inject ApplicationDbContext _context

@{
    int unread = 0;

    var userId = Context.Session.GetInt32("UserId");

    if (userId != null)
    {
        unread = _context.Notifications
            .Count(x => x.UserId == userId && !x.IsRead);
    }
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>BloodLink</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        /* ── NAVBAR ── */
        .navbar {
            background: linear-gradient(135deg, #b71c1c 0%, #d32f2f 100%) !important;
            min-height: 64px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.18);
        }

        .navbar-brand {
            font-weight: 800;
            font-size: 1.4rem;
            letter-spacing: 0.5px;
            color: #fff !important;
        }

        /* ── SEARCH ── */
        .search-form {
            display: flex;
            align-items: center;
            background: rgba(255,255,255,0.15);
            border-radius: 8px;
            overflow: hidden;
            border: 1.5px solid rgba(255,255,255,0.25);
            transition: background 0.2s, border-color 0.2s;
        }

            .search-form:focus-within {
                background: rgba(255,255,255,0.22);
                border-color: rgba(255,255,255,0.5);
            }

            .search-form input {
                background: transparent;
                border: none;
                color: #fff;
                padding: 8px 12px;
                width: 200px;
                font-size: 0.86rem;
                outline: none;
            }

                .search-form input::placeholder {
                    color: rgba(255,255,255,0.65);
                }

            .search-form button {
                background: rgba(255,255,255,0.2);
                border: none;
                border-left: 1.5px solid rgba(255,255,255,0.2);
                color: #fff;
                padding: 8px 12px;
                font-size: 0.9rem;
                cursor: pointer;
                transition: background 0.2s;
            }

                .search-form button:hover {
                    background: rgba(255,255,255,0.3);
                }

        /* ── NOTIFICATION BELL ── */
        .bell-link {
            color: #fff !important;
            padding: 8px 12px !important;
            border-radius: 8px;
            transition: background 0.2s;
        }

            .bell-link:hover {
                background: rgba(255,255,255,0.15);
            }

        /* ── AUTH BUTTONS (chưa đăng nhập) — dùng chung 1 class, y chang nhau ── */
        .auth-buttons {
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .auth-buttons a.btn-auth {
                display: inline-block;
                color: #fff !important;
                background: rgba(255,255,255,0.15);
                border: 1.5px solid rgba(255,255,255,0.6);
                font-size: 0.88rem;
                font-weight: 600;
                padding: 7px 18px;
                border-radius: 999px;
                text-decoration: none;
                transition: all 0.15s;
            }

                .auth-buttons a.btn-auth:hover {
                    background: rgba(255,255,255,0.28);
                    color: #fff !important;
                    border-color: #fff;
                }

        /* ── WELCOME DROPDOWN (đã đăng nhập) ── */
        .nav-dropdown {
            position: relative;
        }

        .welcome-toggle {
            background: rgba(255,255,255,0.15);
            border: 1.5px solid rgba(255,255,255,0.3);
            color: #fff;
            font-size: 0.88rem;
            font-weight: 600;
            padding: 7px 16px;
            border-radius: 20px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: background 0.2s;
        }

            .welcome-toggle:hover {
                background: rgba(255,255,255,0.25);
            }

            .welcome-toggle .caret {
                font-size: 0.6rem;
                opacity: 0.75;
                transition: transform 0.2s;
            }

        .nav-dropdown.show .caret {
            transform: rotate(180deg);
        }

        .nav-dropdown-menu {
            display: none;
            position: absolute;
            right: 0;
            top: 100%;
            padding-top: 8px;
            min-width: 210px;
            z-index: 999;
        }

        .nav-dropdown.show .nav-dropdown-menu {
            display: block;
        }

        .nav-dropdown-menu-inner {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.18);
            overflow: hidden;
            border: 1px solid #f0f0f0;
        }

        .nav-dropdown-menu a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 11px 18px;
            font-size: 0.88rem;
            color: #333;
            text-decoration: none;
            border-bottom: 1px solid #f5f5f5;
            transition: background 0.15s, color 0.15s;
        }

            .nav-dropdown-menu a:last-child {
                border-bottom: none;
            }

            .nav-dropdown-menu a:hover {
                background: #fff5f5;
                color: #d32f2f;
            }

            .nav-dropdown-menu a i {
                width: 16px;
                text-align: center;
                color: #d32f2f;
                font-size: 0.85rem;
            }

            .nav-dropdown-menu a.logout-link {
                color: #d32f2f;
                font-weight: 600;
            }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
        <div class="container">

            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                BloodLink
            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarContent">

                <form class="search-form ms-auto me-3"
                      asp-controller="Home"
                      asp-action="Search"
                      method="get">
                    <input type="search" name="keyword" placeholder="Tìm người hiến, bệnh viện..." aria-label="Search" />
                    <button type="submit" aria-label="Tìm kiếm">
                        <i class="bi bi-search"></i>
                    </button>
                </form>

                <ul class="navbar-nav align-items-lg-center gap-2">

                    @if (Context.Session.GetString("FullName") != null)
                    {
                        <!-- Chuông thông báo -->
                        <li class="nav-item">
                            <a class="nav-link bell-link position-relative"
                               asp-controller="Notification"
                               asp-action="Index">

                                <i class="bi bi-bell-fill fs-5"></i>

                                @if (unread > 0)
                                {
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-warning text-dark">
                                        @unread
                                    </span>
                                }
                            </a>
                        </li>

                        <!-- Welcome + dropdown -->
                        <li class="nav-item nav-dropdown" id="welcomeDropdown">
                            <button class="welcome-toggle" type="button">
                                <i class="bi bi-person-circle"></i>
                                Chào, @Context.Session.GetString("FullName")
                                <span class="caret">▼</span>
                            </button>
                            <div class="nav-dropdown-menu">
                                <div class="nav-dropdown-menu-inner">
                                    <a asp-controller="Account" asp-action="Profile">
                                        <i class="bi bi-person"></i> Xem hồ sơ
                                    </a>
                                    <a asp-controller="BloodRequest" asp-action="Index">
                                        <i class="bi bi-droplet-fill"></i> Đăng ký hiến máu
                                    </a>
                                    <a asp-controller="Account" asp-action="Logout" class="logout-link">
                                        <i class="bi bi-box-arrow-right"></i> Đăng xuất
                                    </a>
                                </div>
                            </div>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <div class="auth-buttons">
                                <a class="btn-auth" asp-controller="Account" asp-action="Login">
                                    Đăng nhập
                                </a>
                                <a class="btn-auth" asp-controller="Account" asp-action="Register">
                                    Đăng ký
                                </a>
                            </div>
                        </li>
                    }

                </ul>

            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1100">
        <div id="notiToast" class="toast align-items-center text-white bg-danger border-0 shadow" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="7000">
            <div class="d-flex">
                <div class="toast-body">
                    <strong class="d-block mb-1"><i class="bi bi-exclamation-triangle-fill me-2"></i> <span id="toastTitle">Thông báo khẩn cấp</span></strong>
                    <span id="toastBody">Bạn có thông báo mới cần hiến máu!</span>
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>

    <audio id="notiAudio" src="https://assets.mixkit.co/active_storage/sfx/2869/2869-600.wav" preload="auto"></audio>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // ── Hover dropdown "Chào, {tên}" giữ lâu hơn ──
        (function () {
            var dropdown = document.getElementById('welcomeDropdown');
            if (!dropdown) return;

            var hideTimer;

            dropdown.addEventListener('mouseenter', function () {
                clearTimeout(hideTimer);
                dropdown.classList.add('show');
            });

            dropdown.addEventListener('mouseleave', function () {
                hideTimer = setTimeout(function () {
                    dropdown.classList.remove('show');
                }, 350);
            });

            var toggleBtn = dropdown.querySelector('.welcome-toggle');
            toggleBtn.addEventListener('click', function (e) {
                e.stopPropagation();
                dropdown.classList.toggle('show');
            });

            document.addEventListener('click', function () {
                dropdown.classList.remove('show');
            });
        })();

        document.addEventListener("DOMContentLoaded", function () {
            var isLoggedIn = '@(Context.Session.GetInt32("UserId") != null)' === 'True';

            if (isLoggedIn) {
                function checkNewNotification() {
                    fetch('/Notification/GetLatestUnreadNotification')
                        .then(response => response.json())
                        .then(data => {
                            if (data.hasNew) {
                                document.getElementById("toastTitle").innerText = data.title;
                                document.getElementById("toastBody").innerText = data.message;

                                document.getElementById("notiAudio")
                                    .play()
                                    .catch(() => { });

                                new bootstrap.Toast(document.getElementById("notiToast")).show();
                            }
                        })
                        .catch(err => console.error("Lỗi kiểm tra thông báo:", err));
                }

                checkNewNotification();
                setInterval(checkNewNotification, 15000);
            }
        });
    </script>

</body>
</html>