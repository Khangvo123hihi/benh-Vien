@using Microsoft.AspNetCore.Http
@using benhvien.Data
@inject ApplicationDbContext _context

@{
    int unread = 0;

    var userId = Context.Session.GetInt32("UserId");

    if (userId != null)
    {
        unread = _context.Notifications
            .Count(x => x.UserId == userId && !x.IsRead);
    }
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>BloodLink</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        .search-box {
            width: 300px;
        }

        .navbar-brand {
            font-weight: bold;
            font-size: 24px;
        }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-danger">
        <div class="container">

            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                BloodLink
            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarContent">

                <form class="d-flex ms-auto me-3"
                      asp-controller="Home"
                      asp-action="Search"
                      method="get">

                    <input class="form-control search-box"
                           type="search"
                           name="keyword"
                           placeholder="Tìm người hiến máu, bệnh viện..."
                           aria-label="Search">

                    <button class="btn btn-light ms-2"
                            type="submit">
                        🔍 Tìm
                    </button>

                </form>

                <ul class="navbar-nav">

                    @if (Context.Session.GetString("FullName") != null)
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white position-relative"
                               asp-controller="Notification"
                               asp-action="Index">

                                <i class="bi bi-bell-fill fs-5"></i>

                                @if (unread > 0)
                                {
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-warning text-dark">
                                        @unread
                                    </span>
                                }

                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-white fw-bold"
                               asp-controller="Account"
                               asp-action="Profile">
                                👤 Hồ sơ của tôi
                            </a>
                        </li>

                        <li class="nav-item">
                            <span class="nav-link">
                                Xin chào,
                                @Context.Session.GetString("FullName")
                            </span>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Account"
                               asp-action="Logout">
                                Logout
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Account"
                               asp-action="Login">
                                Login
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Account"
                               asp-action="Register">
                                Register
                            </a>
                        </li>
                    }

                </ul>

            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1100">
        <div id="notiToast" class="toast align-items-center text-white bg-danger border-0 shadow" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="7000">
            <div class="d-flex">
                <div class="toast-body">
                    <strong class="d-block mb-1"><i class="bi bi-exclamation-triangle-fill me-2"></i> <span id="toastTitle">Thông báo khẩn cấp</span></strong>
                    <span id="toastBody">Bạn có thông báo mới cần hiến máu!</span>
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>

    <audio id="notiAudio" src="https://assets.mixkit.co/active_storage/sfx/2869/2869-600.wav" preload="auto"></audio>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Kiểm tra xem User đã đăng nhập chưa thông qua sự tồn tại của nút Hồ sơ
           var isLoggedIn = '@(Context.Session.GetInt32("UserId") != null)' === 'True';

            if (isLoggedIn) {
                // Hàm tự động gọi lên Server lấy thông báo mới nhất chưa đọc
                function checkNewNotification() {
                    fetch('/Notification/GetLatestUnreadNotification')
                        .then(response => response.json())
                        .then(data => {
                                   if (data.hasNew) {

            document.getElementById("toastTitle").innerText = data.title;
            document.getElementById("toastBody").innerText = data.message;

            document.getElementById("notiAudio")
                .play()
                .catch(() => { });

            new bootstrap.Toast(document.getElementById("notiToast")).show();
        }
                        })
                        .catch(err => console.error("Lỗi kiểm tra thông báo:", err));
                }

                // Chạy kiểm tra ngay khi load xong trang
                checkNewNotification();

                // Cứ mỗi 15 giây tự quét ngầm lại một lần để bắt bài đăng mới của bệnh viện nếu user đang treo máy
                setInterval(checkNewNotification, 15000);
            }
        });
    </script>

</body>
</html>