@model benhvien.Models.HealthDeclaration

@{
    ViewData["Title"] = "Phiếu khai báo sức khỏe";
}

<style>
    .form-hero {
        background: linear-gradient(135deg, #b71c2b 0%, #e63950 60%, #ff6b7a 100%);
        border-radius: 16px 16px 0 0;
        padding: 1.6rem 2rem;
        color: #fff;
    }

        .form-hero h4 {
            font-weight: 700;
            margin: 0;
        }

        .form-hero p {
            margin: 0.2rem 0 0;
            opacity: 0.9;
            font-size: 0.92rem;
        }

    .declaration-card {
        border: none;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 8px 28px rgba(0, 0, 0, 0.09);
    }

    .form-section {
        margin-bottom: 2.2rem;
    }

    .form-section-title {
        font-weight: 700;
        color: #495057;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1.1rem;
        font-size: 1.05rem;
    }

        .form-section-title i {
            color: #d90429;
        }

    .form-label {
        font-weight: 600;
        color: #495057;
        font-size: 0.9rem;
    }

    .form-control,
    .form-select {
        border-radius: 10px;
        border: 1px solid #e2e2e2;
        padding: 0.55rem 0.8rem;
        transition: border-color 0.15s ease;
    }

        .form-control:hover,
        .form-select:hover {
            border-color: #f1a6ae;
        }

        .form-control:focus,
        .form-select:focus {
            border-color: #e63950;
            box-shadow: 0 0 0 0.2rem rgba(230, 57, 80, 0.15);
        }

    .screening-item {
        background: #fff8f8;
        border: 1px solid #ffe3e6;
        border-radius: 12px;
        padding: 0.9rem 1.1rem;
        margin-bottom: 0.85rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        transition: box-shadow 0.15s ease;
    }

        .screening-item:hover {
            box-shadow: 0 3px 12px rgba(217, 4, 41, 0.08);
        }

        .screening-item .form-label {
            flex: 1;
            margin: 0;
        }

        .screening-item .form-select {
            width: 150px;
            flex-shrink: 0;
        }

    @@media (max-width: 576px) {
        .screening-item {
            flex-direction: column;
            align-items: stretch;
        }

            .screening-item .form-select {
                width: 100%;
            }
    }

    .btn-submit {
        background: linear-gradient(135deg, #d90429, #ef233c);
        border: none;
        border-radius: 10px;
        font-weight: 600;
        padding: 0.65rem 1.6rem;
        color: #fff;
        transition: transform 0.15s ease, opacity 0.15s ease;
    }

        .btn-submit:hover {
            color: #fff;
            opacity: 0.92;
            transform: translateY(-2px);
        }

    .btn-cancel {
        border-radius: 10px;
        font-weight: 600;
        padding: 0.65rem 1.6rem;
    }
</style>

<div class="container mt-4">
    <div class="card declaration-card">

        <div class="form-hero">
            <h4><i class="bi bi-clipboard2-pulse-fill me-2"></i>Phiếu khai báo sức khỏe</h4>
            <p>Vui lòng khai báo trung thực trước khi hiến máu</p>
        </div>

        <div class="card-body p-4">

            <form asp-action="Create" method="post">

                <input type="hidden" name="bloodRequestId" value="@ViewBag.BloodRequestId" />

                <div class="form-section">
                    <p class="form-section-title"><i class="bi bi-heart-pulse-fill"></i>Chỉ số cơ thể</p>
                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Cân nặng (kg)</label>
                            <input asp-for="Weight" class="form-control" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Chiều cao (cm)</label>
                            <input asp-for="Height" class="form-control" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Nhiệt độ (°C)</label>
                            <input asp-for="Temperature" class="form-control" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Huyết áp</label>
                            <input asp-for="BloodPressure" class="form-control"
                                   placeholder="Ví dụ: 120/80" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Ngày hiến máu gần nhất</label>
                            <input asp-for="LastDonationDate"
                                   type="date"
                                   class="form-control" />
                        </div>

                    </div>
                </div>

                <div class="form-section">
                    <p class="form-section-title"><i class="bi bi-patch-question-fill"></i>Câu hỏi sàng lọc</p>

                    <div class="screening-item">
                        <label class="form-label">
                            Bạn có đang bị bệnh không?
                        </label>

                        <select asp-for="IsSick" class="form-select">
                            <option value="">-- Chọn --</option>
                            <option value="true">Có</option>
                            <option value="false">Không</option>
                        </select>
                    </div>

                    <div class="screening-item">
                        <label class="form-label">
                            Bạn có đang sử dụng thuốc không?
                        </label>

                        <select asp-for="IsTakingMedicine" class="form-select">
                            <option value="">-- Chọn --</option>
                            <option value="true">Có</option>
                            <option value="false">Không</option>
                        </select>
                    </div>

                    <div class="screening-item">
                        <label class="form-label">
                            Bạn có nguy cơ mắc bệnh truyền nhiễm không?
                        </label>

                        <select asp-for="HasInfectiousRisk" class="form-select">
                            <option value="">-- Chọn --</option>
                            <option value="true">Có</option>
                            <option value="false">Không</option>
                        </select>
                    </div>

                    <div class="screening-item">
                        <label class="form-label">
                            Bạn có uống rượu bia trong 24 giờ qua không?
                        </label>

                        <select asp-for="DrinkAlcohol24h" class="form-select">
                            <option value="">-- Chọn --</option>
                            <option value="true">Có</option>
                            <option value="false">Không</option>
                        </select>
                    </div>

                    <div class="screening-item">
                        <label class="form-label">
                            Bạn có xăm hoặc xỏ khuyên trong vòng 6 tháng qua không?
                        </label>

                        <select asp-for="HasTattooRecently" class="form-select">
                            <option value="">-- Chọn --</option>
                            <option value="true">Có</option>
                            <option value="false">Không</option>
                        </select>
                    </div>
                </div>

                <div class="form-section">
                    <p class="form-section-title"><i class="bi bi-journal-text"></i>Thông tin bổ sung</p>

                    <div class="mb-3">
                        <label class="form-label">
                            Tiền sử bệnh
                        </label>

                        <textarea asp-for="MedicalHistory"
                                  class="form-control"
                                  rows="3"></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">
                            Ghi chú
                        </label>

                        <textarea asp-for="Note"
                                  class="form-control"
                                  rows="3"></textarea>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-submit">
                        <i class="bi bi-arrow-right-circle-fill me-1"></i>Tiếp tục đăng ký hiến máu
                    </button>

                    <a asp-controller="BloodRequest"
                       asp-action="Index"
                       class="btn btn-outline-secondary btn-cancel">
                        Hủy
                    </a>
                </div>

            </form>

        </div>
    </div>
</div>
