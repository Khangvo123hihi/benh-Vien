@model List<benhvien.Models.Hospital>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-hospital"></i> Danh Sách Bệnh Viện Đối Tác</h2>
        <a asp-action="CreateHospital" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Thêm bệnh viện mới
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 25%">Tên Bệnh Viện</th>
                        <th style="width: 35%">Địa Chỉ</th>
                        <th style="width: 15%">Điện Thoại</th>
                        <th style="width: 10%" class="text-center">Tài khoản</th>
                        <th style="width: 15%" class="text-center">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-primary">@item.Name</td>
                                <td>@item.Address</td>
                                <td>@item.Phone</td>
                                <td class="text-center">
                                    <span class="badge bg-info text-dark px-2 py-1">
                                        @(item.Users != null ? item.Users.Count : 0) Đã cấp
                                    </span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a asp-action="EditHospital" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-warning" title="Chỉnh sửa">
                                            Sửa
                                        </a>
                                        <a asp-action="DeleteHospital"
                                           asp-route-id="@item.Id"
                                           class="btn btn-danger btn-sm">
                                            Xóa
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">Chưa có bệnh viện nào trong danh sách.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>