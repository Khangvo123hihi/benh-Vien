@{
    ViewData["Title"] = "Đăng nhập";
}

<style>
    body {
        background: #f5f5f5;
    }

    .login-container {
        min-height: 85vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .login-card {
        width: 100%;
        max-width: 500px;
        border: none;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 8px 25px rgba(0,0,0,0.15);
    }

    .login-header {
        background: #d62828;
        color: white;
        text-align: center;
        padding: 25px;
    }

    .login-header h2 {
        margin: 0;
        font-weight: 700;
    }

    .login-body {
        padding: 35px;
        background: white;
    }

    .form-control {
        height: 50px;
        border-radius: 10px;
    }

    .btn-login {
        background: #d62828;
        color: white;
        height: 50px;
        border-radius: 10px;
        font-weight: 600;
    }

    .btn-login:hover {
        background: #b71c1c;
        color: white;
    }

    .register-btn {
        height: 50px;
        border-radius: 10px;
    }

    .blood-icon {
        font-size: 50px;
        margin-bottom: 10px;
    }
</style>

<div class="login-container">

    <div class="card login-card">

        <div class="login-header">

            <div class="blood-icon">
                🩸
            </div>

            <h2>BLOOD LINK</h2>

            <p class="mb-0">
                Đăng nhập hệ thống hiến máu
            </p>

        </div>

        <div class="login-body">

            <form asp-controller="Account" asp-action="Login" method="post">

                <div class="mb-3">

                    <label class="form-label">
                        Email
                    </label>

                    <input type="email"
                           name="email"
                           class="form-control"
                           placeholder="Nhập email" />

                </div>

                <div class="mb-3">

                    <label class="form-label">
                        Mật khẩu
                    </label>

                    <input type="password"
                           name="password"
                           class="form-control"
                           placeholder="Nhập mật khẩu" />

                </div>

                <div class="d-flex justify-content-between mb-3">

                    <a asp-controller="Account"
                       asp-action="ForgotPassword"
                       class="text-danger text-decoration-none">
                        Quên mật khẩu?
                    </a>

                    <a asp-controller="Account"
                       asp-action="ChangePassword"
                       class="text-danger text-decoration-none">
                        Đổi mật khẩu
                    </a>

                </div>

                <button type="submit"
                        class="btn btn-login w-100">

                    Đăng nhập

                </button>

            </form>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger mt-3">
                    @ViewBag.Error
                </div>
            }

            <hr />

            <div class="text-center">

                <p class="mb-3">
                    Chưa có tài khoản?
                </p>

                <a asp-controller="Account"
                   asp-action="Register"
                   class="btn btn-outline-danger register-btn w-100">

                    Đăng ký ngay

                </a>

            </div>

        </div>

    </div>

</div>