@{
    ViewData["Title"] = "Đăng nhập";
}
<style>
    body {
        background: #f5f5f5;
    }

    .login-container {
        min-height: 85vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 20px 0;
    }

    .login-card {
        width: 100%;
        max-width: 480px;
        border: none;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1), 0 5px 15px rgba(0, 0, 0, 0.07);
    }

    .login-header {
        background: linear-gradient(135deg, #e63946 0%, #d62828 100%);
        color: white;
        text-align: center;
        padding: 32px 24px;
    }

        .login-header .icon-circle {
            width: 64px;
            height: 64px;
            background: rgba(255, 255, 255, 0.15);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 12px;
            font-size: 28px;
        }

        .login-header h2 {
            margin: 0;
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        .login-header p {
            margin: 6px 0 0;
            color: rgba(255, 255, 255, 0.85);
            font-size: 0.9rem;
        }

    .login-body {
        padding: 32px 30px;
        background: white;
    }

    .form-group-icon {
        margin-bottom: 18px;
    }

        .form-group-icon label {
            font-weight: 600;
            font-size: 0.85rem;
            color: #495057;
            margin-bottom: 6px;
            display: block;
        }

    .input-icon-wrap {
        position: relative;
    }

        .input-icon-wrap .field-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #adb5bd;
            z-index: 5;
            pointer-events: none;
            display: flex;
            align-items: center;
        }

        .input-icon-wrap .form-control {
            height: 48px;
            padding-left: 40px;
            border-radius: 10px;
            border: 1.5px solid #e9ecef;
            transition: all 0.2s ease;
        }

            .input-icon-wrap .form-control:focus {
                border-color: #e63946;
                box-shadow: 0 0 0 0.2rem rgba(230, 57, 70, 0.15);
            }

    .link-row a {
        font-size: 0.85rem;
        color: #d62828;
        text-decoration: none;
        font-weight: 500;
    }

        .link-row a:hover {
            text-decoration: underline;
        }

    .btn-login {
        background: linear-gradient(135deg, #e63946 0%, #d62828 100%);
        color: white;
        height: 50px;
        border: none;
        border-radius: 10px;
        font-weight: 700;
        letter-spacing: 0.4px;
        transition: transform 0.15s ease, box-shadow 0.15s ease;
    }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 16px rgba(214, 40, 57, 0.3);
            color: white;
        }

    .register-btn {
        height: 50px;
        border-radius: 10px;
        border: 1.5px solid #d62828;
        color: #d62828;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .register-btn:hover {
            background: #d62828;
            color: white;
        }

    .error-box {
        background: #fdecea;
        color: #c0392b;
        border-radius: 8px;
        padding: 10px 14px;
        font-size: 0.9rem;
        margin-top: 16px;
        border-left: 4px solid #e63946;
    }
</style>

<div class="login-container">
    <div class="card login-card">
        <div class="login-header">
            <div class="icon-circle">
                <i class="bi bi-droplet-fill"></i>
            </div>
            <h2>BLOOD LINK</h2>
            <p>Đăng nhập hệ thống hiến máu</p>
        </div>
        <div class="login-body">
            <form asp-controller="Account" asp-action="Login" method="post">
                <div class="form-group-icon">
                    <label>Email</label>
                    <div class="input-icon-wrap">
                        <i class="bi bi-envelope-fill field-icon"></i>
                        <input type="email" name="email" class="form-control" placeholder="Nhập email" />
                    </div>
                </div>

                <div class="form-group-icon">
                    <label>Mật khẩu</label>
                    <div class="input-icon-wrap">
                        <i class="bi bi-lock-fill field-icon"></i>
                        <input type="password" name="password" class="form-control" placeholder="Nhập mật khẩu" />
                    </div>
                </div>

                <div class="d-flex justify-content-between mb-3 link-row">
                    <a asp-controller="Account" asp-action="ForgotPassword">
                        Quên mật khẩu?
                    </a>
                    <a asp-controller="Account" asp-action="ChangePassword">
                        Đổi mật khẩu
                    </a>
                </div>

                <button type="submit" class="btn btn-login w-100">
                    <i class="bi bi-box-arrow-in-right me-1"></i> Đăng nhập
                </button>
            </form>

            @if (ViewBag.Error != null)
            {
                <div class="error-box">
                    <i class="bi bi-exclamation-triangle-fill me-1"></i> @ViewBag.Error
                </div>
            }

            <hr class="my-4" />

            <div class="text-center">
                <p class="mb-3 text-muted">Chưa có tài khoản?</p>
                <a asp-controller="Account" asp-action="Register" class="btn register-btn w-100">
                    <i class="bi bi-person-plus-fill me-1"></i> Đăng ký ngay
                </a>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">