@model benhvien.Models.User

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-header bg-danger text-white">
                <h3 class="text-center">Đăng ký tài khoản</h3>
            </div>

            <div class="card-body">
                <h4 class="text-danger">@ViewBag.Error</h4>
                <form method="post">

                    <div class="mb-3">
                        <label>Họ tên</label>
                        <input asp-for="FullName" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>Email</label>
                        <input asp-for="Email" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>Số điện thoại</label>
                        <input asp-for="Phone" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>Password</label>
                        <input asp-for="Password" type="password" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="fw-bold">Nhóm máu</label>
                        <select asp-for="BloodTypeId" name="BloodTypeId" class="form-control" required>
                            <option value="">-- Chọn nhóm máu --</option>
                            <option value="1">O+</option>
                            <option value="2">O-</option>
                            <option value="3">A+</option>
                            <option value="4">A-</option>
                            <option value="5">B+</option>
                            <option value="6">B-</option>
                            <option value="7">AB+</option>
                            <option value="8">AB-</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label>Tuổi</label> <input asp-for="Age" type="number" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>Địa chỉ</label>
                        <input asp-for="Address" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>Loại tài khoản</label>
                        <select asp-for="RoleId" class="form-control">
                            <option value="4">Cá nhân</option>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-danger w-100">Đăng ký</button>
                </form>
            </div>
        </div>
    </div>
</div>